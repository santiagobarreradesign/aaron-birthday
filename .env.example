# Copy to ".env.local" and fill from Firebase Console → Project settings → Your apps.
# For GitHub Pages: add the same names as Repository secrets (Settings → Secrets and variables → Actions).
# Variable names must match exactly (VITE_* is required for Vite to expose them to the client bundle).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
